rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {       
  
  match /plans/{planId} {
      allow read: if true; 
      allow create, update, delete: if request.auth != null 
        && request.auth.uid == "eCqjINFsQsOMyNFCS87DggmlgN93";
    }
    
  match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
  match /transactions/{userId}/userTransactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      allow create: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.data.cardId is string
        && request.resource.data.cardId.size() > 0;
      
      allow update: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.data.cardId is string
        && request.resource.data.cardId.size() > 0;
      
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
  match /users/{userId} {
	  allow read: if request.auth != null && request.auth.uid == "eCqjINFsQsOMyNFCS87DggmlgN93";
  	allow write: if request.auth != null && request.auth.uid == userId;  
  }    
  
  match /cards/{cardId} {
    allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
  }  

  match /notifications/{notificationId} {
    allow read: if request.auth != null;
    allow create, delete: if request.auth != null
      && request.auth.uid == "eCqjINFsQsOMyNFCS87DggmlgN93";
    allow update: if request.auth != null
      && (
        request.auth.uid == "eCqjINFsQsOMyNFCS87DggmlgN93"
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
      );
  }
  
  }
}